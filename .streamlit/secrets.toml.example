# תבנית סודות ל-Streamlit Cloud.
# בענן: העתק את התוכן הזה אל Settings -> Secrets באפליקציה, ומלא ערכים אמיתיים.
# מקומית: אפשר להעתיק ל-.streamlit/secrets.toml (כבר ב-.gitignore) או להמשיך להשתמש ב-.env.

OPENAI_API_KEY = "sk-..."
FINNHUB_API_KEY = "..."
EMAIL_SENDER = "you@gmail.com"
EMAIL_APP_PASSWORD = "your-16-char-app-password"
EMAIL_RECIPIENT = "you@gmail.com"
WATCHLIST = "AAPL,MSFT,TSLA,NVDA,TEVA"
